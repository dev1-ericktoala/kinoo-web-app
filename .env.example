# Copia a `.env.local` o `.env` (Next.js los carga en desarrollo).

# Debe coincidir con el prefijo del router del backend (p. ej. FastAPI include_router(..., prefix="/api/v1")).
# Sin `/api/v1` el cliente llama a `/auth/login` en la raíz del host y el servidor responde 404.
NEXT_PUBLIC_API_BASE_URL=https://tu-backend.com/api/v1

# Google Maps (JavaScript API), opcional para el mapa de promociones.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
